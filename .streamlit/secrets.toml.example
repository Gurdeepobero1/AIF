# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Community Cloud, add these under App Settings → Secrets.

# Sarvam AI — Speech-to-Text API
# Get your key at: https://www.sarvam.ai
SARVAM_API_KEY = ""

# Twilio — WebRTC ICE servers (optional, improves camera reliability)
# Get credentials at: https://www.twilio.com/console
# Without these, the app falls back to Google's public STUN servers.
TWILIO_ACCOUNT_SID = ""
TWILIO_AUTH_TOKEN = ""
